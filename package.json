{
  "name": "labymaker",
  "version": "1.0.0",
  "description": "Generateur et solveur de labyrinthes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-packager . LabyMaker --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.projet.labymaker",
    "productName": "LabyMaker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  }
}
